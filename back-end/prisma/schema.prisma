generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(uuid())

  nome      String
  email     String   @unique
  senha     String

  createdAt DateTime @default(now())
}

model Centro {
  id          String   @id @default(uuid())

  nome        String
  endereco    String?
  descricao   String?

  eventos     Evento[]

  createdAt   DateTime @default(now())
}

model Evento {
  id          String   @id @default(uuid())

  titulo      String
  descricao   String?

  data        DateTime

  centroId    String

  centro      Centro @relation(fields: [centroId], references: [id])

  createdAt   DateTime @default(now())
}

model Oficina {
  id          String   @id @default(uuid())

  nome        String
  descricao   String?

  createdAt   DateTime @default(now())
}

model Atividade {
  id          String   @id @default(uuid())

  nome        String
  descricao   String?

  createdAt   DateTime @default(now())
}

model Assistencia {
  id          String   @id @default(uuid())

  nome        String
  descricao   String?

  createdAt   DateTime @default(now())
}